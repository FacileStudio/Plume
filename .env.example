# All env vars are optional — defaults work with docker-compose
# DOMAIN=https://app.yourdomain.com

# OIDC (optional)
# OIDC_ISSUER=https://authentik.yourdomain.com/application/o/plume/
# OIDC_CLIENT_ID=your-client-id
# OIDC_CLIENT_SECRET=your-client-secret
# OIDC_REDIRECT_URL=https://api.yourdomain.com/auth/oidc/callback
# OIDC_SUCCESS_URL=https://app.yourdomain.com
# SSO_ONLY=false
